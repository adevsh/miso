# .env.example
#
# Example environment file for local Atlantis and Cloudflare development.
# Keep real secrets in `.env` only; this file exists to document required keys
# and provide a safe template for first-time setup.

# GitHub
ATLANTIS_GH_USER=your-github-user
ATLANTIS_GH_TOKEN=ghp_xxx
ATLANTIS_GH_WEBHOOK_SECRET=replace-with-random-secret

# Cloudflare
CF_TUNNEL_TOKEN=replace-with-cloudflare-tunnel-token
